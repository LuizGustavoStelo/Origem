NODE_ENV=production

# Portas locais usadas pelo Nginx instalado direto na VPS.
WEB_A_PORT=3001
WEB_B_PORT=3002

# Banco PostgreSQL.
POSTGRES_DB=origem
POSTGRES_USER=origem_app
POSTGRES_PASSWORD=troque_esta_senha

# Redis para cache, sessões, filas e rate limiting.
REDIS_PASSWORD=troque_esta_senha_tambem

# Usado pelo deploy quando a imagem vem do GitHub Container Registry.
WEB_IMAGE=origem-web:local
